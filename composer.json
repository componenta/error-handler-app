{
    "name": "componenta/error-handler-app",
    "description": "Componenta application integration for error handling and reporting",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "componenta/app": "^1.0",
        "componenta/config": "^1.0",
        "componenta/error-handler": "^1.0",
        "componenta/http-emitter": "^1.0",
        "componenta/path-resolver": "^1.0",
        "psr/container": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\Error\\App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\Error\\App\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "minimum-stability": "stable",
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\Error\\App\\ConfigProvider"
            ]
        }
    }
}
